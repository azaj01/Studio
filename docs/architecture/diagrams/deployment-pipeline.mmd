    classDef startEnd fill:#4caf50,stroke:#333,stroke-width:2px,color:#fff
    classDef process fill:#2196f3,stroke:#333,stroke-width:2px,color:#fff
    classDef decision fill:#ff9800,stroke:#333,stroke-width:2px,color:#000
    classDef critical fill:#f44336,stroke:#333,stroke-width:2px,color:#fff
    classDef success fill:#8bc34a,stroke:#333,stroke-width:2px,color:#000
    classDef note fill:#e1bee7,stroke:#333,stroke-width:1px,color:#000

    class Start,DeployEnd startEnd
    class MinikubeStart,StartMinikube,EnableIngress,DeleteOldBackend,DeleteLocalBackend,DeleteOldFrontend,DeleteLocalFrontend,DeleteOldDevServer,DeleteLocalDevServer,LoadBackend,LoadFrontend,LoadDevServer,DeleteBackendPod,DeleteFrontendPod,WaitBackend,WaitFrontend,VerifyBackend,VerifyFrontend,AccessMinikube,TestLocal,ConfigureAWS,UpdateKubeconfig,LoginECR,BuildEKSBackend,TagEKSBackend,PushEKSBackend,BuildEKSFrontend,TagEKSFrontend,PushEKSFrontend,BuildEKSDevServer,TagEKSDevServer,PushEKSDevServer,DeleteBackendPodEKS,DeleteFrontendPodEKS,WaitBackendEKS,WaitFrontendEKS,RestartIngress,WaitIngressReady,VerifyEKS,CheckCertManager,FixCerts,AccessEKS,TestProd,MonitorLogs process
    class ChooseEnv,MinikubeCluster,ChooseImage,ChooseEKSImage,CheckCerts decision
    class BuildBackendNoCache,BuildFrontendNoCache,BuildDevServerNoCache critical
    class MinikubeComplete,EKSComplete,EKSDevServerReady success
    class Note1,Note2,Note3 note
