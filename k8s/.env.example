# ============================================================================
# Tesslate Studio - Kubernetes Environment Configuration
# ============================================================================
# Copy this file to:
#   - k8s/.env.minikube  (for local development)
#   - k8s/.env.production (for production deployment)
#
# Then run: ./scripts/generate-secrets-from-env.sh [minikube|production]
# ============================================================================

# ----------------------------------------------------------------------------
# Environment Type
# ----------------------------------------------------------------------------
K8S_ENVIRONMENT=minikube

# ----------------------------------------------------------------------------
# Domain Configuration
# ----------------------------------------------------------------------------
# For minikube: localhost
# For production: your-domain.com
APP_DOMAIN=localhost
APP_PROTOCOL=http

# Email for Let's Encrypt SSL certificates (production only)
SSL_EMAIL=

# ----------------------------------------------------------------------------
# Database Configuration
# ----------------------------------------------------------------------------
POSTGRES_DB=tesslate_dev
POSTGRES_USER=tesslate_user
POSTGRES_PASSWORD=your-postgres-password-here

# ----------------------------------------------------------------------------
# Application Secret Key
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# ----------------------------------------------------------------------------
SECRET_KEY=your-secret-key-here

# ----------------------------------------------------------------------------
# LiteLLM Configuration (Required for AI features)
# ----------------------------------------------------------------------------
LITELLM_API_BASE=https://your-litellm-instance.com/v1
LITELLM_MASTER_KEY=your-litellm-master-key
LITELLM_DEFAULT_MODELS=claude-sonnet-4.6,claude-opus-4.6
LITELLM_TEAM_ID=default
LITELLM_EMAIL_DOMAIN=localhost
LITELLM_INITIAL_BUDGET=10000.0

# ----------------------------------------------------------------------------
# OAuth Configuration (Optional - leave empty to disable)
# ----------------------------------------------------------------------------
# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=

# ----------------------------------------------------------------------------
# Stripe Payment Configuration (Optional)
# ----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# Stripe Per-Tier Price IDs (monthly)
STRIPE_BASIC_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_ULTRA_PRICE_ID=

# Stripe Per-Tier Price IDs (annual)
STRIPE_BASIC_ANNUAL_PRICE_ID=
STRIPE_PRO_ANNUAL_PRICE_ID=
STRIPE_ULTRA_ANNUAL_PRICE_ID=

# Pricing Configuration (all amounts in cents)
TIER_PRICE_BASIC=2000
TIER_PRICE_PRO=4900
TIER_PRICE_ULTRA=14900

# Credit packages (1:1 ratio, $1 = 100 credits)
CREDIT_PACKAGE_SMALL=500
CREDIT_PACKAGE_MEDIUM=2500
CREDIT_PACKAGE_LARGE=10000
CREDIT_PACKAGE_TEAM=50000

ADDITIONAL_DEPLOY_PRICE=1000

# Signup bonus
SIGNUP_BONUS_CREDITS=15000
SIGNUP_BONUS_EXPIRY_DAYS=60

# User Limits
FREE_MAX_PROJECTS=3
BASIC_MAX_PROJECTS=7
PRO_MAX_PROJECTS=15
ULTRA_MAX_PROJECTS=40

# Revenue Split
CREATOR_REVENUE_SHARE=0.90
PLATFORM_REVENUE_SHARE=0.10

# ----------------------------------------------------------------------------
# S3/MinIO Configuration (for project hibernation)
# ----------------------------------------------------------------------------
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=tesslate-projects
S3_ENDPOINT_URL=http://minio.minio-system.svc.cluster.local:9000
S3_REGION=us-east-1

# ----------------------------------------------------------------------------
# PostHog Analytics (Optional)
# ----------------------------------------------------------------------------
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=

# ----------------------------------------------------------------------------
# Cookie Security
# ----------------------------------------------------------------------------
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=.localhost

# ----------------------------------------------------------------------------
# Container Registry (Production only)
# ----------------------------------------------------------------------------
DOCR_TOKEN=
