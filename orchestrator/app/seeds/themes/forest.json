{
  "id": "forest",
  "name": "Forest",
  "mode": "dark",
  "author": "Tesslate",
  "version": "1.0.0",
  "description": "Natural green theme for eco-friendly vibes",
  "category": "vibrant",
  "tags": ["dark", "green", "nature", "forest"],
  "icon": "tree",

  "colors": {
    "primary": "#22c55e",
    "primaryHover": "#4ade80",
    "primaryRgb": "34, 197, 94",
    "accent": "#84cc16",

    "background": "#0f1410",
    "surface": "#1a201a",
    "surfaceHover": "#242c24",

    "text": "#ffffff",
    "textMuted": "rgba(255, 255, 255, 0.6)",
    "textSubtle": "rgba(255, 255, 255, 0.4)",

    "border": "rgba(255, 255, 255, 0.08)",
    "borderHover": "rgba(255, 255, 255, 0.15)",

    "sidebar": {
      "background": "#0a0f0a",
      "text": "#ffffff",
      "border": "rgba(255, 255, 255, 0.06)",
      "hover": "rgba(34, 197, 94, 0.08)",
      "active": "rgba(34, 197, 94, 0.15)"
    },

    "input": {
      "background": "#1a201a",
      "border": "rgba(255, 255, 255, 0.1)",
      "borderFocus": "#22c55e",
      "text": "#ffffff",
      "placeholder": "rgba(255, 255, 255, 0.4)"
    },

    "scrollbar": {
      "thumb": "rgba(34, 197, 94, 0.3)",
      "thumbHover": "rgba(34, 197, 94, 0.5)",
      "track": "transparent"
    },

    "code": {
      "inlineBackground": "rgba(34, 197, 94, 0.15)",
      "inlineText": "#86efac",
      "blockBackground": "rgba(0, 0, 0, 0.4)",
      "blockBorder": "rgba(34, 197, 94, 0.2)",
      "blockText": "#e2e2e2"
    },

    "status": {
      "error": "#f87171",
      "errorRgb": "248, 113, 113",
      "success": "#4ade80",
      "successRgb": "74, 222, 128",
      "warning": "#fbbf24",
      "warningRgb": "251, 191, 36",
      "info": "#60a5fa",
      "infoRgb": "96, 165, 250"
    },

    "shadow": {
      "small": "0 1px 2px rgba(0, 0, 0, 0.4)",
      "medium": "0 4px 6px rgba(0, 0, 0, 0.4)",
      "large": "0 10px 15px rgba(0, 0, 0, 0.4)"
    }
  },

  "typography": {
    "fontFamily": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
    "fontFamilyMono": "JetBrains Mono, Menlo, Monaco, 'Courier New', monospace",
    "fontSizeBase": "14px",
    "lineHeight": "1.5"
  },

  "spacing": {
    "radiusSmall": "4px",
    "radiusMedium": "6px",
    "radiusLarge": "8px",
    "radiusXl": "12px"
  },

  "animation": {
    "durationFast": "150ms",
    "durationNormal": "200ms",
    "durationSlow": "300ms",
    "easing": "cubic-bezier(0.4, 0, 0.2, 1)"
  }
}
