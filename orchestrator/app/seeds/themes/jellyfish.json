  "animation": {
    "durationFast": "150ms",
    "durationNormal": "200ms",
    "durationSlow": "300ms",
    "easing": "cubic-bezier(0.4, 0, 0.2, 1)"
  },
  "category": "vibrant",
  "tags": [
    "dark",
    "pink",
    "blue",
    "ocean"
  ],
  "icon": "waves"
