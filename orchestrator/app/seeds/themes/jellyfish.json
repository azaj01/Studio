{
  "id": "jellyfish",
  "name": "JellyFish Theme",
  "mode": "dark",
  "author": "PawelBorkar",
  "version": "1.0.0",
  "description": "Deep ocean-inspired theme with hot pink and sky blue highlights",
  "colors": {
    "primary": "#e83d84",
    "primaryHover": "#f06098",
    "primaryRgb": "232, 61, 132",
    "accent": "#48c6ef",
    "background": "#161b22",
    "surface": "#1c222b",
    "surfaceHover": "#242c37",
    "text": "#ffffff",
    "textMuted": "rgba(255, 255, 255, 0.6)",
    "textSubtle": "rgba(255, 255, 255, 0.4)",
    "border": "rgba(255, 255, 255, 0.08)",
    "borderHover": "rgba(255, 255, 255, 0.15)",
    "sidebar": {
      "background": "#11151c",
      "text": "#ffffff",
      "border": "rgba(255, 255, 255, 0.06)",
      "hover": "rgba(232, 61, 132, 0.08)",
      "active": "rgba(232, 61, 132, 0.15)"
    },
    "input": {
      "background": "#1c222b",
      "border": "rgba(255, 255, 255, 0.1)",
      "borderFocus": "#e83d84",
      "text": "#ffffff",
      "placeholder": "rgba(255, 255, 255, 0.4)"
    },
    "scrollbar": {
      "thumb": "rgba(232, 61, 132, 0.3)",
      "thumbHover": "rgba(232, 61, 132, 0.5)",
      "track": "transparent"
    },
    "code": {
      "inlineBackground": "rgba(232, 61, 132, 0.15)",
      "inlineText": "#f07aa6",
      "blockBackground": "rgba(0, 0, 0, 0.4)",
      "blockBorder": "rgba(232, 61, 132, 0.2)",
      "blockText": "#e2e2e2"
    },
    "status": {
      "error": "#f87171",
      "errorRgb": "248, 113, 113",
      "success": "#4ade80",
      "successRgb": "74, 222, 128",
      "warning": "#fbbf24",
      "warningRgb": "251, 191, 36",
      "info": "#60a5fa",
      "infoRgb": "96, 165, 250"
    },
    "shadow": {
      "small": "0 1px 2px rgba(0, 0, 0, 0.4)",
      "medium": "0 4px 6px rgba(0, 0, 0, 0.4)",
      "large": "0 10px 15px rgba(0, 0, 0, 0.4)"
    }
  },
  "typography": {
    "fontFamily": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
    "fontFamilyMono": "JetBrains Mono, Menlo, Monaco, 'Courier New', monospace",
    "fontSizeBase": "14px",
    "lineHeight": "1.5"
  },
  "spacing": {
    "radiusSmall": "4px",
    "radiusMedium": "6px",
    "radiusLarge": "8px",
    "radiusXl": "12px"
