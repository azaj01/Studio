{
  "id": "c-cpp-themes",
  "name": "C/C++ Themes",
  "mode": "dark",
  "author": "Microsoft",
  "version": "1.0.0",
  "description": "Microsoft's official C/C++ dark theme with cyan blue and gold syntax highlights",
  "colors": {
    "primary": "#4fc1ff",
    "primaryHover": "#74d0ff",
    "primaryRgb": "79, 193, 255",
    "accent": "#dcdcaa",
    "background": "#1e1e1e",
    "surface": "#252526",
    "surfaceHover": "#2d2d30",
    "text": "#ffffff",
    "textMuted": "rgba(255, 255, 255, 0.6)",
    "textSubtle": "rgba(255, 255, 255, 0.4)",
    "border": "rgba(255, 255, 255, 0.08)",
    "borderHover": "rgba(255, 255, 255, 0.15)",
    "sidebar": {
      "background": "#181818",
      "text": "#ffffff",
      "border": "rgba(255, 255, 255, 0.06)",
      "hover": "rgba(79, 193, 255, 0.08)",
      "active": "rgba(79, 193, 255, 0.15)"
    },
    "input": {
      "background": "#252526",
      "border": "rgba(255, 255, 255, 0.1)",
      "borderFocus": "#4fc1ff",
      "text": "#ffffff",
      "placeholder": "rgba(255, 255, 255, 0.4)"
    },
    "scrollbar": {
      "thumb": "rgba(79, 193, 255, 0.3)",
      "thumbHover": "rgba(79, 193, 255, 0.5)",
      "track": "transparent"
    },
    "code": {
      "inlineBackground": "rgba(79, 193, 255, 0.15)",
      "inlineText": "#7fd4ff",
      "blockBackground": "rgba(0, 0, 0, 0.4)",
      "blockBorder": "rgba(79, 193, 255, 0.2)",
      "blockText": "#e2e2e2"
    },
    "status": {
      "error": "#f87171",
      "errorRgb": "248, 113, 113",
      "success": "#4ade80",
      "successRgb": "74, 222, 128",
      "warning": "#fbbf24",
      "warningRgb": "251, 191, 36",
      "info": "#60a5fa",
      "infoRgb": "96, 165, 250"
    },
    "shadow": {
      "small": "0 1px 2px rgba(0, 0, 0, 0.4)",
      "medium": "0 4px 6px rgba(0, 0, 0, 0.4)",
      "large": "0 10px 15px rgba(0, 0, 0, 0.4)"
    }
  },
  "typography": {
    "fontFamily": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
    "fontFamilyMono": "JetBrains Mono, Menlo, Monaco, 'Courier New', monospace",
    "fontSizeBase": "14px",
    "lineHeight": "1.5"
  },
  "spacing": {
    "radiusSmall": "4px",
    "radiusMedium": "6px",
    "radiusLarge": "8px",
    "radiusXl": "12px"
  },
  "animation": {
    "durationFast": "150ms",
    "durationNormal": "200ms",
    "durationSlow": "300ms",
    "easing": "cubic-bezier(0.4, 0, 0.2, 1)"
  },
  "category": "professional",
  "tags": [
    "dark",
    "cyan",
    "microsoft",
    "systems"
  ],
  "icon": "brackets-curly"
}
