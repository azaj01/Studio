{
  "id": "night-owl",
  "name": "Night Owl",
  "mode": "dark",
  "author": "Sarah Drasner",
  "version": "1.0.0",
  "description": "A deep blue theme designed for night coders and accessibility",
  "colors": {
    "primary": "#7fdbca",
    "primaryHover": "#a5e8d9",
    "primaryRgb": "127, 219, 202",
    "accent": "#c792ea",
    "background": "#011627",
    "surface": "#01121f",
    "surfaceHover": "#0b2942",
    "text": "#ffffff",
    "textMuted": "rgba(255, 255, 255, 0.6)",
    "textSubtle": "rgba(255, 255, 255, 0.4)",
    "border": "rgba(255, 255, 255, 0.08)",
    "borderHover": "rgba(255, 255, 255, 0.15)",
    "sidebar": {
      "background": "#010e1a",
      "text": "#ffffff",
      "border": "rgba(255, 255, 255, 0.06)",
      "hover": "rgba(127, 219, 202, 0.08)",
      "active": "rgba(127, 219, 202, 0.15)"
    },
    "input": {
      "background": "#01121f",
      "border": "rgba(255, 255, 255, 0.1)",
      "borderFocus": "#7fdbca",
      "text": "#ffffff",
      "placeholder": "rgba(255, 255, 255, 0.4)"
    },
    "scrollbar": {
      "thumb": "rgba(127, 219, 202, 0.3)",
      "thumbHover": "rgba(127, 219, 202, 0.5)",
      "track": "transparent"
    },
    "code": {
      "inlineBackground": "rgba(127, 219, 202, 0.15)",
      "inlineText": "#a5e8d9",
      "blockBackground": "rgba(0, 0, 0, 0.4)",
      "blockBorder": "rgba(127, 219, 202, 0.2)",
      "blockText": "#e2e2e2"
    },
    "status": {
      "error": "#f87171",
      "errorRgb": "248, 113, 113",
      "success": "#4ade80",
      "successRgb": "74, 222, 128",
      "warning": "#fbbf24",
      "warningRgb": "251, 191, 36",
      "info": "#60a5fa",
      "infoRgb": "96, 165, 250"
    },
    "shadow": {
      "small": "0 1px 2px rgba(0, 0, 0, 0.4)",
      "medium": "0 4px 6px rgba(0, 0, 0, 0.4)",
      "large": "0 10px 15px rgba(0, 0, 0, 0.4)"
    }
  },
  "typography": {
    "fontFamily": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
    "fontFamilyMono": "JetBrains Mono, Menlo, Monaco, 'Courier New', monospace",
    "fontSizeBase": "14px",
    "lineHeight": "1.5"
  },
  "spacing": {
    "radiusSmall": "4px",
    "radiusMedium": "6px",
    "radiusLarge": "8px",
    "radiusXl": "12px"
  },
  "animation": {
    "durationFast": "150ms",
    "durationNormal": "200ms",
    "durationSlow": "300ms",
    "easing": "cubic-bezier(0.4, 0, 0.2, 1)"
  },
  "category": "professional",
  "tags": [
    "dark",
    "teal",
    "night",
    "accessible"
  ],
  "icon": "bird"
}
