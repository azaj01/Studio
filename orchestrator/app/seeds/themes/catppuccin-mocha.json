{
  "id": "catppuccin-mocha",
  "name": "Catppuccin Mocha",
  "mode": "dark",
  "author": "Catppuccin",
  "version": "1.0.0",
  "description": "Soothing pastel theme with warm mauve and pink tones",
  "colors": {
    "primary": "#cba6f7",
    "primaryHover": "#dbbfff",
    "primaryRgb": "203, 166, 247",
    "accent": "#f5c2e7",
    "background": "#1e1e2e",
    "surface": "#181825",
    "surfaceHover": "#262637",
    "text": "#ffffff",
    "textMuted": "rgba(255, 255, 255, 0.6)",
    "textSubtle": "rgba(255, 255, 255, 0.4)",
    "border": "rgba(255, 255, 255, 0.08)",
    "borderHover": "rgba(255, 255, 255, 0.15)",
    "sidebar": {
      "background": "#11111b",
      "text": "#ffffff",
      "border": "rgba(255, 255, 255, 0.06)",
      "hover": "rgba(203, 166, 247, 0.08)",
      "active": "rgba(203, 166, 247, 0.15)"
    },
    "input": {
      "background": "#181825",
      "border": "rgba(255, 255, 255, 0.1)",
      "borderFocus": "#cba6f7",
      "text": "#ffffff",
      "placeholder": "rgba(255, 255, 255, 0.4)"
    },
    "scrollbar": {
      "thumb": "rgba(203, 166, 247, 0.3)",
      "thumbHover": "rgba(203, 166, 247, 0.5)",
      "track": "transparent"
    },
    "code": {
      "inlineBackground": "rgba(203, 166, 247, 0.15)",
      "inlineText": "#dcc0ff",
      "blockBackground": "rgba(0, 0, 0, 0.4)",
      "blockBorder": "rgba(203, 166, 247, 0.2)",
      "blockText": "#e2e2e2"
    },
    "status": {
      "error": "#f87171",
      "errorRgb": "248, 113, 113",
      "success": "#4ade80",
      "successRgb": "74, 222, 128",
      "warning": "#fbbf24",
      "warningRgb": "251, 191, 36",
      "info": "#60a5fa",
      "infoRgb": "96, 165, 250"
    },
    "shadow": {
      "small": "0 1px 2px rgba(0, 0, 0, 0.4)",
      "medium": "0 4px 6px rgba(0, 0, 0, 0.4)",
      "large": "0 10px 15px rgba(0, 0, 0, 0.4)"
    }
  },
  "typography": {
    "fontFamily": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
    "fontFamilyMono": "JetBrains Mono, Menlo, Monaco, 'Courier New', monospace",
    "fontSizeBase": "14px",
    "lineHeight": "1.5"
  },
  "spacing": {
    "radiusSmall": "4px",
    "radiusMedium": "6px",
    "radiusLarge": "8px",
    "radiusXl": "12px"
  },
  "animation": {
    "durationFast": "150ms",
    "durationNormal": "200ms",
    "durationSlow": "300ms",
    "easing": "cubic-bezier(0.4, 0, 0.2, 1)"
  },
  "category": "minimal",
  "tags": [
    "dark",
    "pastel",
    "mauve",
    "catppuccin"
  ],
  "icon": "coffee"
}
