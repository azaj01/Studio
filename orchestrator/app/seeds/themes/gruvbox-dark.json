{
  "id": "gruvbox-dark",
  "name": "Gruvbox Dark",
  "mode": "dark",
  "author": "Pavel Pertsev",
  "version": "1.0.0",
  "description": "Retro groove color scheme with warm earthy tones and high contrast",
  "colors": {
