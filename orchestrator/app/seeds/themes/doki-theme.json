{
  "id": "doki-theme",
  "name": "Doki Theme",
  "mode": "dark",
  "author": "Unthrottled",
  "version": "1.0.0",
  "description": "Anime-inspired dark theme with sakura pink and soft lavender tones",
  "colors": {
    "primary": "#f06292",
    "primaryHover": "#f48baf",
    "primaryRgb": "240, 98, 146",
    "accent": "#ba68c8",
    "background": "#1a1a2e",
    "surface": "#212140",
    "surfaceHover": "#2a2a50",
    "text": "#ffffff",
    "textMuted": "rgba(255, 255, 255, 0.6)",
    "textSubtle": "rgba(255, 255, 255, 0.4)",
    "border": "rgba(255, 255, 255, 0.08)",
    "borderHover": "rgba(255, 255, 255, 0.15)",
    "sidebar": {
      "background": "#141428",
      "text": "#ffffff",
      "border": "rgba(255, 255, 255, 0.06)",
      "hover": "rgba(240, 98, 146, 0.08)",
      "active": "rgba(240, 98, 146, 0.15)"
    },
    "input": {
      "background": "#212140",
      "border": "rgba(255, 255, 255, 0.1)",
      "borderFocus": "#f06292",
      "text": "#ffffff",
      "placeholder": "rgba(255, 255, 255, 0.4)"
    },
    "scrollbar": {
      "thumb": "rgba(240, 98, 146, 0.3)",
      "thumbHover": "rgba(240, 98, 146, 0.5)",
      "track": "transparent"
    },
    "code": {
      "inlineBackground": "rgba(240, 98, 146, 0.15)",
      "inlineText": "#f79cba",
      "blockBackground": "rgba(0, 0, 0, 0.4)",
      "blockBorder": "rgba(240, 98, 146, 0.2)",
      "blockText": "#e2e2e2"
    },
    "status": {
      "error": "#f87171",
      "errorRgb": "248, 113, 113",
      "success": "#4ade80",
      "successRgb": "74, 222, 128",
      "warning": "#fbbf24",
      "warningRgb": "251, 191, 36",
      "info": "#60a5fa",
      "infoRgb": "96, 165, 250"
    },
    "shadow": {
      "small": "0 1px 2px rgba(0, 0, 0, 0.4)",
      "medium": "0 4px 6px rgba(0, 0, 0, 0.4)",
      "large": "0 10px 15px rgba(0, 0, 0, 0.4)"
    }
  },
  "typography": {
    "fontFamily": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
    "fontFamilyMono": "JetBrains Mono, Menlo, Monaco, 'Courier New', monospace",
    "fontSizeBase": "14px",
    "lineHeight": "1.5"
  },
  "spacing": {
    "radiusSmall": "4px",
    "radiusMedium": "6px",
    "radiusLarge": "8px",
    "radiusXl": "12px"
  },
  "animation": {
    "durationFast": "150ms",
    "durationNormal": "200ms",
    "durationSlow": "300ms",
    "easing": "cubic-bezier(0.4, 0, 0.2, 1)"
  },
  "category": "vibrant",
  "tags": [
    "dark",
    "pink",
    "anime",
    "cute"
  ],
  "icon": "heart"
}
