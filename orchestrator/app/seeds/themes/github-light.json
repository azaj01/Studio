{
  "id": "github-light",
  "name": "GitHub Light",
  "mode": "light",
  "author": "GitHub",
  "version": "1.0.0",
  "description": "GitHub's official light theme with clean blue accents",
  "colors": {
    "primary": "#0969da",
    "primaryHover": "#0550ae",
    "primaryRgb": "9, 105, 218",
    "accent": "#1a7f37",
    "background": "#ffffff",
    "surface": "#f6f8fa",
    "surfaceHover": "#eaeef2",
    "text": "#1f2328",
    "textMuted": "rgba(31, 35, 40, 0.6)",
    "textSubtle": "rgba(31, 35, 40, 0.4)",
    "border": "rgba(31, 35, 40, 0.15)",
    "borderHover": "rgba(31, 35, 40, 0.25)",
    "sidebar": {
      "background": "#f6f8fa",
      "text": "#1f2328",
      "border": "rgba(31, 35, 40, 0.1)",
      "hover": "rgba(9, 105, 218, 0.06)",
      "active": "rgba(9, 105, 218, 0.12)"
    },
    "input": {
      "background": "#ffffff",
      "border": "rgba(31, 35, 40, 0.15)",
      "borderFocus": "#0969da",
      "text": "#1f2328",
      "placeholder": "rgba(31, 35, 40, 0.4)"
    },
    "scrollbar": {
      "thumb": "rgba(31, 35, 40, 0.2)",
      "thumbHover": "rgba(31, 35, 40, 0.35)",
      "track": "transparent"
    },
    "code": {
      "inlineBackground": "rgba(9, 105, 218, 0.1)",
      "inlineText": "#0550ae",
      "blockBackground": "rgba(0, 0, 0, 0.04)",
      "blockBorder": "rgba(31, 35, 40, 0.1)",
      "blockText": "#374151"
    },
    "status": {
      "error": "#dc2626",
      "errorRgb": "220, 38, 38",
      "success": "#16a34a",
      "successRgb": "22, 163, 74",
      "warning": "#d97706",
      "warningRgb": "217, 119, 6",
      "info": "#2563eb",
      "infoRgb": "37, 99, 235"
    },
    "shadow": {
      "small": "0 1px 2px rgba(0, 0, 0, 0.06)",
      "medium": "0 4px 6px rgba(0, 0, 0, 0.08)",
      "large": "0 10px 15px rgba(0, 0, 0, 0.1)"
    }
  },
  "typography": {
    "fontFamily": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
    "fontFamilyMono": "JetBrains Mono, Menlo, Monaco, 'Courier New', monospace",
    "fontSizeBase": "14px",
    "lineHeight": "1.5"
  },
  "spacing": {
    "radiusSmall": "4px",
    "radiusMedium": "6px",
    "radiusLarge": "8px",
    "radiusXl": "12px"
  },
  "animation": {
    "durationFast": "150ms",
    "durationNormal": "200ms",
    "durationSlow": "300ms",
    "easing": "cubic-bezier(0.4, 0, 0.2, 1)"
  },
  "category": "professional",
  "tags": [
    "light",
    "github",
    "blue",
    "clean"
  ],
  "icon": "github-logo"
}
